/* ── CodePractice TUI Theme — Claude-inspired dark palette ────────────────── */

/* Global defaults */
Screen {
    background: #0d1117;
    color: #c9d1d9;
}

/* ── Header ─────────────────────────────────────────────────────────────── */

#app-header {
    dock: top;
    height: 3;
    background: #161b22;
    color: #58a6ff;
    content-align: center middle;
    text-style: bold;
    border-bottom: solid #30363d;
    padding: 0 2;
}

#app-header .nav-item {
    margin: 0 1;
    color: #8b949e;
}

#app-header .nav-item:hover {
    color: #58a6ff;
    text-style: bold;
}

/* ── Sidebar ────────────────────────────────────────────────────────────── */

#sidebar {
    dock: left;
    width: 28;
    background: #161b22;
    border-right: solid #30363d;
    padding: 1 0;
}

#sidebar .nav-button {
    width: 100%;
    height: 3;
    background: transparent;
    color: #c9d1d9;
    content-align: left middle;
    padding: 0 2;
    text-style: none;
    border: none;
    margin: 0;
}

#sidebar .nav-button:hover {
    background: #1c2128;
    color: #58a6ff;
}

#sidebar .nav-button.active {
    background: #1f6feb;
    color: #ffffff;
    text-style: bold;
}

#sidebar .section-label {
    color: #484f58;
    padding: 1 2 0 2;
    text-style: italic;
}

/* ── Content Area ───────────────────────────────────────────────────────── */

#content {
    padding: 1 2;
}

/* ── Panels & Cards ─────────────────────────────────────────────────────── */

.panel {
    background: #161b22;
    border: solid #30363d;
    padding: 1 2;
    margin: 1 0;
}

.panel-title {
    text-style: bold;
    color: #58a6ff;
    margin-bottom: 1;
}

.card {
    background: #161b22;
    border: solid #30363d;
    padding: 1 2;
    margin: 0 1 1 0;
    height: auto;
}

.card:hover {
    border: solid #58a6ff;
}

.card-title {
    text-style: bold;
    color: #c9d1d9;
}

/* ── Problem Card ───────────────────────────────────────────────────────── */

.problem-card {
    background: #161b22;
    border: solid #30363d;
    padding: 1 2;
    margin: 1 0;
}

.problem-title {
    text-style: bold;
    color: #ffffff;
}

.problem-description {
    color: #c9d1d9;
    margin: 1 0;
}

/* ── Difficulty badges ──────────────────────────────────────────────────── */

.badge-easy {
    color: #3fb950;
    text-style: bold;
}

.badge-medium {
    color: #d29922;
    text-style: bold;
}

.badge-hard {
    color: #f85149;
    text-style: bold;
}

/* ── Stats ──────────────────────────────────────────────────────────────── */

.stat-value {
    text-style: bold;
    color: #58a6ff;
}

.stat-label {
    color: #8b949e;
}

/* ── Code editor ────────────────────────────────────────────────────────── */

.code-editor {
    background: #0d1117;
    border: solid #30363d;
    padding: 0;
    min-height: 12;
}

.code-editor:focus {
    border: solid #58a6ff;
}

/* ── Streaming output ───────────────────────────────────────────────────── */

.streaming-output {
    background: #161b22;
    border: solid #30363d;
    padding: 1 2;
    overflow-y: auto;
    min-height: 6;
    max-height: 30;
}

/* ── Chat messages ──────────────────────────────────────────────────────── */

.chat-user {
    background: #1f6feb;
    color: #ffffff;
    padding: 1 2;
    margin: 0 8 1 0;
    text-align: left;
}

.chat-assistant {
    background: #1c2128;
    color: #c9d1d9;
    padding: 1 2;
    margin: 0 0 1 8;
}

/* ── Buttons ────────────────────────────────────────────────────────────── */

.primary-btn {
    background: #1f6feb;
    color: #ffffff;
    padding: 0 3;
    text-style: bold;
    min-width: 16;
    border: none;
}

.primary-btn:hover {
    background: #58a6ff;
}

.secondary-btn {
    background: #30363d;
    color: #c9d1d9;
    padding: 0 3;
    min-width: 12;
    border: none;
}

.secondary-btn:hover {
    background: #484f58;
}

.danger-btn {
    background: #f85149;
    color: #ffffff;
    padding: 0 3;
    border: none;
}

/* ── Welcome banner ─────────────────────────────────────────────────────── */

#welcome-banner {
    content-align: center middle;
    height: auto;
    padding: 1;
    color: #58a6ff;
}

/* ── Progress indicators ────────────────────────────────────────────────── */

.progress-bar {
    color: #3fb950;
}

.progress-track {
    color: #30363d;
}

/* ── Grid layouts ───────────────────────────────────────────────────────── */

.action-grid {
    layout: grid;
    grid-size: 3;
    grid-gutter: 1;
    padding: 1;
}

.two-col {
    layout: grid;
    grid-size: 2;
    grid-gutter: 1;
}

/* ── Tabs & tab content ─────────────────────────────────────────────────── */

ContentSwitcher {
    height: 1fr;
}

TabPane {
    padding: 1;
}

/* ── Footer ─────────────────────────────────────────────────────────────── */

#footer {
    dock: bottom;
    height: 1;
    background: #161b22;
    color: #484f58;
    content-align: center middle;
    border-top: solid #30363d;
}

/* ── DataTable styling ──────────────────────────────────────────────────── */

DataTable {
    background: #161b22;
    color: #c9d1d9;
}

DataTable > .datatable--header {
    background: #1c2128;
    color: #8b949e;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: #1f6feb;
    color: #ffffff;
}

/* ── Input ──────────────────────────────────────────────────────────────── */

Input {
    background: #0d1117;
    border: solid #30363d;
    color: #c9d1d9;
}

Input:focus {
    border: solid #58a6ff;
}

/* ── TextArea ───────────────────────────────────────────────────────────── */

TextArea {
    background: #0d1117;
    border: solid #30363d;
}

TextArea:focus {
    border: solid #58a6ff;
}

/* ── Select & option lists ──────────────────────────────────────────────── */

Select {
    background: #161b22;
    border: solid #30363d;
}

OptionList {
    background: #161b22;
    border: solid #30363d;
}

OptionList > .option-list--option-highlighted {
    background: #1f6feb;
    color: #ffffff;
}
