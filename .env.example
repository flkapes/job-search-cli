# codepractice environment configuration
# Copy this to .env and fill in your values

# LLM Backend: "ollama" or "lmstudio"
LLM_BACKEND=ollama

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# LM Studio settings (uses OpenAI-compatible API)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model

# App data directory (default: ~/.codepractice)
# CODEPRACTICE_DATA_DIR=/path/to/custom/dir

# Enable debug mode (shows raw LLM prompts)
DEBUG=false
